// ─────────────────────────────────────────────────────────────────────────────
// DAILY CONTEXT LOG (Gemini nightly summary — one row per trading day)
// Written by daily_context_summarizer.py at ~9 PM NST
// Read by learning_hub.py (GPT Sunday review) — one clean row per day
// instead of 40+ intraday rows from geopolitical_data / nepal_pulse
// ─────────────────────────────────────────────────────────────────────────────

model daily_context_log {
  id                   Serial
  date                 Text!  @unique    // YYYY-MM-DD trading day

  // ── Scores (end-of-day final values)
  geo_score_eod        Text             // final geo_score of the day (-5 to +5)
  nepal_score_eod      Text             // final nepal_score of the day (-5 to +5)
  combined_score_eod   Text             // geo + nepal combined
  nepse_index_eod      Text             // NEPSE composite closing value
  nepse_change_pct     Text             // % change vs previous day

  // ── International
  dxy_value            Text             // DXY close (validated signal)
  dxy_change_pct       Text             // DXY % change vs previous day

  // ── Market breadth
  market_state         Text             // BULL | BEAR | SIDEWAYS from settings
  advancing            Text             // advancing stocks count
  declining            Text             // declining stocks count
  breadth_score        Text             // market_breadth.breadth_score
  total_turnover_npr   Text             // total market turnover

  // ── Macro (carried forward from nrb_monthly — stable monthly)
  policy_rate          Text             // NRB policy rate
  fd_rate_pct          Text             // current avg FD rate from settings
  lending_rate         Text             // from nrb_monthly
  bop_status           Text             // from nrb_monthly
  overall_sentiment    Text             // nrb_monthly overall_sentiment

  // ── Gemini narrative summaries
  key_events_summary   Text             // 4-6 sentence narrative of the day
  nepal_pulse_highlights Text           // top 3 events from nepal_pulse.key_event
  geo_summary          Text             // Gemini summary of geo/international movements
  nrb_macro_summary    Text             // 2-line NRB macro context (refreshed monthly)

  // ── Signals issued that day (from market_log)
  signals_summary      Text             // e.g. "BUY: NABIL(82%), NHPC(71%) | AVOID: NICA(65%) | WAIT: GBBL(58%)"
  buy_count            Text             // count of BUY signals
  wait_count           Text             // count of WAIT signals
  avoid_count          Text             // count of AVOID signals

  gate_miss_count        Text    // how many symbols blocked today
  gate_top_category      Text    // CONF_SCORE | TECH_SCORE | RSI_OVERBOUGHT etc
  gate_false_block_pct   Text    // rolling 30d false block rate at summary time
  signals_avg_confidence Text    // avg Claude confidence across all signals today

  // ── Metadata
  source               Text  @default("gemini_nightly")
  backfilled           Text  @default("false")  // true if generated retroactively
  created_at           Text

  // ---headilines
   headlines_political TEXT
   headlines_economy   TEXT
    headlines_nepse     TEXT

  @@index([date])
}

