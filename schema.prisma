}

// db_schema is managed internally by db/migrations.py — do not touch
model db_schema {
  id             Serial
  migration_id   Text!  @unique
  name           Text!
  applied_at     Text
  rolled_back_at Text
  status         Text  @default("applied")
  notes          Text
}

// ─────────────────────────────────────────────────────────────────────────────
// INDEX HISTORY (for statistical analysis / backtester)
// ─────────────────────────────────────────────────────────────────────────────

model nepse_indices {
  id            Serial
  date          Text!
  index_id      Text!
  index_name    Text!
  current_value Text          // closing value
  high          Text
  low           Text
  change_abs    Text
  change_pct    Text
  week52_high   Text
  week52_low    Text
  turnover      Text          // turnover value NPR
  volume        Text          // turnover volume (shares)
  transactions  Text          // total transactions
  source        Text  @default("nepalstock")

  @@unique([date, index_id])
  @@index([date])
  @@index([index_id])
  @@index([index_name])
}
// ─────────────────────────────────────────────────────────────────────────────
// STATISTICAL ANALYSIS RESULTS
// ─────────────────────────────────────────────────────────────────────────────

model macro_stat_results {
  id              Serial
  variable        Text!          // e.g. "cpi_inflation"
  variable_label  Text           // e.g. "CPI Inflation (%)"
  lag_months      Text!          // 0 / 1 / 2 / 3 months
  spearman_rho    Text           // Spearman rank correlation coefficient
  p_value         Text           // Raw p-value (uncorrected)
  p_corrected     Text           // Bonferroni-corrected p-value
  significant     Text           // "true" / "false" — survived Bonferroni
  effect_size     Text           // negligible / small / medium / large
  n_pairs         Text           // Number of valid observation pairs
  rho_3m_forward  Text           // ρ vs NEPSE 3-month forward return
  p_3m_forward    Text           // p-value for 3-month forward correlation
  n_pairs_3m      Text           // n for 3-month forward test
  n_total_tests   Text           // Total tests run (for Bonferroni denominator)
  alpha_corrected Text           // Bonferroni threshold used
  run_date        Text           // YYYY-MM-DD when analysis was run
  notes           Text           // Free text for context

  @@unique([variable, lag_months, run_date])
  @@index([variable])
  @@index([run_date])
}


model fd_rates {
  id               Serial
  fetch_date       Text!          // YYYY-MM-DD when fetched
  institute_code   Text           // e.g. "Janaki Finan."
  institute_name   Text           // e.g. "Janaki Finance Co."
  product_name     Text           // e.g. "Fixed Deposit-2Y&above"
  interest_rate    Text           // raw string e.g. "7.00%"
  interest_pct     Text           // parsed float e.g. "7.00"
  tenure_label     Text           // e.g. "2 years"
  tenure_months    Text           // e.g. "24"
  tenure_category  Text           // SHORT / MEDIUM / LONG / VLONG
  minimum_balance  Text           // e.g. "0"
  institute_type   Text           // bank / finance / dev_bank / other
  source           Text  @default("bankbyaj")

  @@unique([fetch_date, institute_code, product_name])
  @@index([fetch_date])
  @@index([tenure_category])
  @@index([interest_pct])
}

model fd_rate_summary {
  id               Serial
  fetch_date       Text!  @unique  // one summary per fetch date
  avg_rate_pct     Text            // average across all products
  max_rate_pct     Text            // highest rate available
  min_rate_pct     Text            // lowest rate available
  best_bank_name   Text            // institution with best rate
  best_bank_rate   Text            // their rate %
  best_tenure      Text            // their tenure
  rate_vs_prev_pct Text            // change from previous month (+ = rising)
  rate_direction   Text            // RISING / FALLING / UNCHANGED
  fd_score_signal  Text            // STRONG_BUY_STOCKS / BUY_STOCKS / NEUTRAL / PREFER_FD / STRONG_FD
  total_products   Text            // how many products fetched

  @@index([fetch_date])
}