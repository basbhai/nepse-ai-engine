// ─────────────────────────────────────────────────────────────────────────────
// INDICATORS & CANDLES
// ─────────────────────────────────────────────────────────────────────────────

model indicators {
  id               Serial
  symbol           Text!
  date             Text!
  ltp              Text
  prev_close       Text
  volume           Text
  history_days     Text
  rsi_14           Text
  rsi_signal       Text   // OVERSOLD | NEUTRAL | OVERBOUGHT
  ema_20           Text
  ema_50           Text
  ema_200          Text
  ema_trend        Text   // ABOVE_ALL | BELOW_ALL | MIXED
  ema_20_50_cross  Text   // GOLDEN | DEATH | NONE
  ema_50_200_cross Text   // GOLDEN | DEATH | NONE
  macd_line        Text
  macd_signal      Text
  macd_histogram   Text
  macd_cross       Text   // BULLISH | BEARISH | NONE
  bb_upper         Text
  bb_middle        Text
  bb_lower         Text
  bb_width         Text
  bb_pct_b         Text
  bb_signal        Text   // SQUEEZE | EXPANSION | UPPER_TOUCH | LOWER_TOUCH | NEUTRAL
  atr_14           Text
  atr_pct          Text
  obv              Text
  obv_trend        Text   // RISING | FALLING | FLAT
  tech_score       Text   // 0–100
  tech_signal      Text   // STRONG_BULL | BULL | NEUTRAL | BEAR | STRONG_BEAR
  timestamp        Text

  @@unique([symbol, date])
  @@index([date])
  @@index([tech_signal])
}

model candle_patterns {
  id                 Serial
  pattern_name       Text!  @unique
  type               Text   // BULLISH | BEARISH | NEUTRAL
  tier               Text   // 1 | 2 | 3
  nepal_win_rate_pct Text
  sample_size        Text
  avg_gain_pct       Text
  best_sector        Text
  best_rsi_range     Text
  volume_condition   Text
  reliability        Text
  notes              Text
}

model candle_signals {
  id               Serial
  symbol           Text!
  date             Text!
  pattern_name     Text!
  signal           Text   // BULLISH | BEARISH | NEUTRAL
  tier             Text   // 1 | 2 | 3
  confidence       Text
  volume_confirmed Text   // "true" | "false"
  candles_used     Text
  description      Text
  timestamp        Text

  @@unique([symbol, date, pattern_name])
  @@index([date])
  @@index([symbol])
  @@index([signal])
}

// ─────────────────────────────────────────────────────────────────────────────
// GEO & MACRO CONTEXT
// ─────────────────────────────────────────────────────────────────────────────

model geopolitical_data {
