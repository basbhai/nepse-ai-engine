// schema.prisma — NEPSE AI Engine
// Single source of truth for all tables.
// Edit here, then run: python db/codegen.py → python -m db.migrations
//
// Type conventions:
//   Text     — nullable TEXT column (most columns)
//   Text!    — NOT NULL TEXT column
//   Serial   — SERIAL PRIMARY KEY (auto-increment id)
//   Boolean  — TEXT storing "true"/"false" (kept as Text for simplicity)
//
// Annotations:
//   @id              — PRIMARY KEY
//   @unique          — UNIQUE INDEX
//   @default("val")  — DEFAULT value
//   @@index([col])   — regular index
//   @@index([a, b])  — composite index

// ─────────────────────────────────────────────────────────────────────────────
// PRICE & MARKET DATA
// ─────────────────────────────────────────────────────────────────────────────

model price_history {
  id           Serial
  date         Text!          // YYYY-MM-DD
  symbol       Text!
  open         Text
  high         Text
  low          Text
  close        Text
  ltp          Text
  volume       Text
  turnover     Text
  vwap         Text
  prev_close   Text
  transactions Text
  conf_score   Text
  avg_120d     Text
  avg_180d     Text
  week52_high  Text
  week52_low   Text
  source       Text  @default("sharesansar")

  @@unique([date, symbol])
  @@index([symbol])
  @@index([date])
}

model market_breadth {
  id                Serial
  date              Text!  @unique
  advancing         Text
  declining         Text
  unchanged         Text
  new_52w_high      Text
  new_52w_low       Text
  total_turnover_npr Text
  total_volume      Text
  breadth_score     Text
  market_signal     Text
  nepse_index       Text
  nepse_change_pct  Text
  timestamp         Text

  @@index([date])
}

// ─────────────────────────────────────────────────────────────────────────────
// WATCHLIST & PORTFOLIO
// ─────────────────────────────────────────────────────────────────────────────

model watchlist {
  id                Serial
  symbol            Text!  @unique
  company           Text
  sector            Text
  added_date        Text
  fundamental_score Text
  technical_score   Text
  combined_score    Text
  last_updated      Text
  sector_momentum   Text
  dividend_yield_pct Text
  pe_ratio          Text
  eps               Text
  npl_pct           Text
  car_pct           Text
  week52_high       Text
  week52_low        Text
  pct_from_52w_high Text
  notes             Text

  @@index([sector])
}

model portfolio {
  id           Serial
  symbol       Text!
  entry_date   Text
  entry_price  Text
  shares       Text
  total_cost   Text
  current_price Text
  current_value Text
  pnl_npr      Text
  pnl_pct      Text
  peak_price   Text
  stop_type    Text
  stop_level   Text
  trail_active Text
  trail_stop   Text
  status       Text  @default("OPEN")
  exit_date    Text
  exit_price   Text
  exit_reason  Text

  @@index([symbol])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// SIGNALS & TRADING LOG
// ─────────────────────────────────────────────────────────────────────────────

model market_log {
