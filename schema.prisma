// schema.prisma — NEPSE AI Engine
// Single source of truth for all tables.
// Edit here, then run: python -m db.codegen → python -m db.migrations
//
// Type conventions:
//   Text     — nullable TEXT column (most columns)
//   Text!    — NOT NULL TEXT column
//   Serial   — SERIAL PRIMARY KEY (auto-increment id)
//   Boolean  — TEXT storing "true"/"false" (kept as Text for simplicity)
//
// Annotations:
//   @id              — PRIMARY KEY
//   @unique          — UNIQUE INDEX
//   @default("val")  — DEFAULT value
//   @@index([col])   — regular index
//   @@index([a, b])  — composite index
//
// Cleanup applied: April 5, 2026
//   DROPPED: watchlist (superseded by share_sectors)
//   DROPPED: macro_data (superseded by nrb_monthly)
//   DROPPED: news_sentiment (no writer/reader existed)
//   REMOVED: market_log.dual_audit, market_log.gpt_verdict (legacy GPT dual-verdict architecture)
//   REMOVED: nepal_pulse.ccd_ratio, .crr, .slr, .trade_deficit_npr (redundant with nrb_monthly)

// ─────────────────────────────────────────────────────────────────────────────
// PRICE & MARKET DATA
// ─────────────────────────────────────────────────────────────────────────────

model price_history {
  id           Serial
  date         Text!          // YYYY-MM-DD
  symbol       Text!
  open         Text
  high         Text
  low          Text
  close        Text
  ltp          Text
  volume       Text
  turnover     Text
  vwap         Text
  prev_close   Text
  transactions Text
  conf_score   Text
  avg_120d     Text
  avg_180d     Text
  week52_high  Text
  week52_low   Text
  source       Text  @default("sharesansar")

  @@unique([date, symbol])
  @@index([symbol])
  @@index([date])
}

model market_breadth {
  id                 Serial
  date               Text!  @unique
  advancing          Text
  declining          Text
  unchanged          Text
  new_52w_high       Text
  new_52w_low        Text
  total_turnover_npr Text
  total_volume       Text
  breadth_score      Text
  market_signal      Text
  nepse_index        Text
  nepse_change_pct   Text
  timestamp          Text

  @@index([date])
}

// ─────────────────────────────────────────────────────────────────────────────
// PORTFOLIO
// ─────────────────────────────────────────────────────────────────────────────

model portfolio {
  id            Serial
  symbol        Text!
  entry_date    Text
  entry_price   Text
  shares        Text
  total_cost    Text
  current_price Text
  current_value Text
  pnl_npr       Text
  pnl_pct       Text
  peak_price    Text
  stop_type     Text
  stop_level    Text
  trail_active  Text
  trail_stop    Text
  status        Text  @default("OPEN")
  exit_date     Text
  exit_price    Text
  exit_reason   Text

  @@index([symbol])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// SIGNALS & TRADING LOG
// ─────────────────────────────────────────────────────────────────────────────

model market_log {
  id               Serial
  date             Text
  time             Text
  symbol           Text
  sector           Text
  action           Text
  confidence       Text
  entry_price      Text
  stop_loss        Text
  target           Text
  allocation_npr   Text
  shares           Text
  breakeven        Text
  risk_reward      Text
  rsi_14           Text
  ema_20           Text
  ema_50           Text
  ema_200          Text
  primary_signal   Text   // top signal that triggered recommendation
  macd_line        Text
  macd_signal      Text
  macd_histogram   Text   // MACD histogram at signal time
  bb_pct_b         Text   // Bollinger %B at signal time
  bb_upper         Text   // Bollinger upper band
  bb_lower         Text   // Bollinger lower band
  bollinger_upper  Text
  bollinger_lower  Text
  ema_20_50_cross  Text   // EMA 20/50 crossover signal
  ema_50_200_cross Text   // EMA 50/200 crossover signal
  volume           Text
  volume_ratio     Text
  obv_trend        Text
  vwap             Text
  vwap_dev         Text   // (ltp - vwap) / vwap — ATrad intraday signal
  bid_ask_ratio    Text   // bid_qty / (bid_qty + ask_qty) — demand pressure 0-1
  dpr_proximity    Text   // (ltp - low_dpr) / (high_dpr - low_dpr) — circuit range position
  volume_os_ratio  Text   // today_volume / outstanding_shares % — smart money signal
  atr_14           Text
  support_level    Text
  resistance_level Text
  candle_pattern   Text
  conf_score       Text
  pe_ratio         Text
  eps              Text
  roe              Text
  npl_pct          Text
  fundamental_score Text
  geo_score        Text
  macro_score      Text
  sector_mult      Text   // sector multiplier applied at decision time
  cstar_signal     Text   // c-star composite signal
  market_state     Text   // BULLISH | BEARISH | SIDEWAYS at signal time
  gemini_reason    Text   // Gemini rationale for recommendation
  gemini_risk      Text   // Gemini identified risk factors
  reasoning        Text
  outcome          Text  @default("PENDING")
  actual_pnl       Text
  exit_price       Text
  exit_date        Text
  exit_reason      Text
  // dual_audit    — REMOVED Apr 5 2026 (legacy GPT dual-verdict architecture)
  // gpt_verdict   — REMOVED Apr 5 2026 (GPT is now weekly coach only)
  timestamp        Text
  eval_date              Text   // date tracker evaluated this
  eval_geo_score         Text   // geo score at evaluation
  eval_nepal_score       Text   // nepal score at evaluation
  eval_nepse_index       Text   // NEPSE index at evaluation
  eval_market_state      Text   // market state at evaluation
  eval_policy_rate       Text   // NRB policy rate at evaluation
  eval_fd_rate_pct       Text   // FD rate at evaluation
  eval_geo_delta         Text   // geo_score_eval - geo_score_entry
  eval_nepal_delta       Text   // nepal_score_eval - nepal_score_entry
  eval_key_news          Text   // 2-3 line highlights from nepal_pulse.key_event
  eval_price_change_pct  Text   // % price move from signal date to eval date
  eval_nepse_change_pct  Text   // NEPSE % move over same period
  eval_alpha             Text   // stock move vs NEPSE — same logic as trade_journal
  headlines_politics     Text   // 1-2 political headlines affecting NEPSE
  headlines_economy      Text   // 1-2 economic/macro headlines
  headlines_stock        Text   // 1-2 stock market specific headlines

  @@index([symbol])
  @@index([date])
  @@index([outcome])
}

// ─────────────────────────────────────────────────────────────────────────────
// INDICATORS & CANDLES
// ─────────────────────────────────────────────────────────────────────────────

model indicators {
  id               Serial
  symbol           Text!
  date             Text!
  volume           Text
  history_days     Text
  rsi_14           Text
  rsi_signal       Text   // OVERSOLD | NEUTRAL | OVERBOUGHT
  ema_20           Text
  ema_50           Text
  ema_200          Text
  ema_trend        Text   // ABOVE_ALL | BELOW_ALL | MIXED
  ema_20_50_cross  Text   // GOLDEN | DEATH | NONE
  ema_50_200_cross Text   // GOLDEN | DEATH | NONE
  macd_line        Text
  macd_signal      Text
  macd_histogram   Text
  macd_cross       Text   // BULLISH | BEARISH | NONE
  bb_upper         Text
  bb_middle        Text
  bb_lower         Text
  bb_width         Text
  bb_pct_b         Text
  bb_signal        Text   // SQUEEZE | EXPANSION | UPPER_TOUCH | LOWER_TOUCH | NEUTRAL
  atr_14           Text
  atr_pct          Text
  obv              Text
  obv_trend        Text   // RISING | FALLING | FLAT
  support_level    Text   // lowest low over last 20 trading days
  resistance_level Text   // highest high over last 20 trading days
  tech_score       Text   // 0–100
  tech_signal      Text   // STRONG_BULL | BULL | NEUTRAL | BEAR | STRONG_BEAR
  timestamp        Text

  @@unique([symbol, date])
  @@index([date])
  @@index([tech_signal])
}

model candle_patterns {
  id                 Serial
  pattern_name       Text!  @unique
  type               Text   // BULLISH | BEARISH | NEUTRAL
  tier               Text   // 1 | 2 | 3
  nepal_win_rate_pct Text
  sample_size        Text
  avg_gain_pct       Text
  best_sector        Text
  best_rsi_range     Text
  volume_condition   Text
  reliability        Text
  notes              Text
}

model candle_signals {
  id               Serial
  symbol           Text!
  date             Text!
  pattern_name     Text!
  signal           Text   // BULLISH | BEARISH | NEUTRAL
  tier             Text   // 1 | 2 | 3
  confidence       Text
  volume_confirmed Text   // "true" | "false"
  candles_used     Text
  description      Text
  timestamp        Text

  @@unique([symbol, date, pattern_name])
  @@index([date])
  @@index([symbol])
  @@index([signal])
}

// ─────────────────────────────────────────────────────────────────────────────
// GEO & MACRO CONTEXT
// ─────────────────────────────────────────────────────────────────────────────

model geopolitical_data {
  id               Serial
  date             Text
  time             Text
  crude_price      Text
  crude_change_pct Text
  vix              Text
  vix_level        Text   // CALM | LOW | ELEVATED | HIGH | EXTREME
  nifty            Text
  nifty_change_pct Text
  dxy              Text
  gold_price       Text
  geo_score        Text   // -5 to +5
  status           Text   // BULLISH | POSITIVE | NEUTRAL | BEARISH | CRISIS
  key_event        Text
  timestamp        Text

  @@index([date])
}

model nepal_pulse {
  id                   Serial
  date                 Text
  time                 Text
  // NRB / Monetary
  policy_rate          Text
  policy_rate_change   Text   // RAISED | CUT | UNCHANGED
  // ccd_ratio         — REMOVED Apr 5 2026 (redundant with nrb_monthly)
  // crr               — REMOVED Apr 5 2026 (redundant with nrb_monthly.crr_percentage)
  // slr               — REMOVED Apr 5 2026 (redundant with nrb_monthly.slr_percentage)
  nrb_event            Text
  // SEBON / Market
  sebon_event          Text
  circuit_breaker      Text
  ipo_fpo_active       Text   // YES | NO
  ipo_fpo_detail       Text
  // Political
  govt_stability       Text   // STABLE | UNSTABLE | CRISIS
  political_event      Text
  budget_season        Text   // YES | NO
  budget_event         Text
  // Economic
  remittance_yoy_pct   Text
  inflation_pct        Text
  forex_reserve_months Text
  // trade_deficit_npr — REMOVED Apr 5 2026 (BOP data is in nrb_monthly)
  // Disruption
  bandh_today          Text   // YES | NO
  bandh_detail         Text
  load_shedding_hrs    Text
  // Score
  nepal_score          Text   // -5 to +5
  nepal_status         Text   // BULLISH | POSITIVE | NEUTRAL | BEARISH | CRISIS
  key_event            Text
  source               Text
  timestamp            Text

  headlines_politics  Text
  headlines_economy   Text
  headlines_stock     Text
  @@index([date])
}

// macro_data — DROPPED Apr 5 2026 (superseded by nrb_monthly since Mar 28 fix)

model nrb_monthly {
  id                                  Serial
  period                              Text!  @unique   // e.g. "fy2025/26-month8"
  fiscal_year                         Text
  month_number                        Text
  is_annual                           Text   @default("false")

  // ── Monetary Policy ───────────────────────────────────────────────────────
  policy_rate                         Text
  bank_rate                           Text
  crr_percentage                      Text
  slr_percentage                      Text

  // ── Interest Rates ────────────────────────────────────────────────────────
  lending_rate_pct                    Text   // commercial banks weighted avg
  deposit_rate_pct                    Text   // commercial banks weighted avg
  interbank_rate_pct                  Text   // weighted avg inter-bank rate
  tbill_91d_rate_pct                  Text   // 91-day T-bill rate

  // ── Inflation & Credit ────────────────────────────────────────────────────
  cpi_inflation                       Text
  credit_growth_rate                  Text   // YoY private sector credit growth
  private_sector_credit_growth_yoy_pct Text  // same as above but explicit YoY
  m2_growth_yoy_pct                   Text
  deposit_growth_yoy_pct              Text
  npl_ratio_pct                       Text   // non-performing loan ratio

  // ── Liquidity ─────────────────────────────────────────────────────────────
  liquidity_injected_billion          Text   // net liquidity absorbed/injected
  liquidity_status                    Text   // SURPLUS | TIGHT | NEUTRAL

  // ── Remittance ────────────────────────────────────────────────────────────
  remittance_yoy_change_pct           Text
  remittance_total_billion_npr        Text   // absolute figure for trend tracking

  // ── Foreign Exchange ──────────────────────────────────────────────────────
  fx_reserve_months                   Text
  usd_npr_rate                        Text   // buying rate mid-period

  // ── Balance of Payments ───────────────────────────────────────────────────
  bop_overall_balance_usd_m           Text
  bop_current_account_usd_m           Text
  bop_capital_account_usd_m           Text   // NEW
  bop_trade_deficit_usd_m             Text   // NEW
  bop_status                          Text   // SURPLUS | DEFICIT
  bop_trend                           Text   // IMPROVING | DETERIORATING | STABLE
  bop_impact_on_nepse                 Text   // one sentence NEPSE liquidity implication

  // ── Capital Market ────────────────────────────────────────────────────────
  nepse_index_value                   Text   // NEPSE index at report date
  nepse_index                         Text   // legacy — keep for backward compat
  market_cap_billion_npr              Text

  // ── Macro Sentiment ───────────────────────────────────────────────────────
  overall_sentiment                   Text   // BULLISH | NEUTRAL | BEARISH
  forward_guidance                    Text   // max 2 sentences
  key_risks                           Text   // max 3 bullets

  @@index([fiscal_year, month_number])
}s

// ─────────────────────────────────────────────────────────────────────────────
// FUNDAMENTALS
// ─────────────────────────────────────────────────────────────────────────────

model fundamentals {
  id                   Int      @id @default(autoincrement())
  symbol               String
  stock_id             Int?
  fiscal_year          String
  quarter              String
  eps                  Float?
  net_worth            Float?
  roe                  Float?
  roa                  Float?
  paidup_capital       Float?
  reserve              Float?
  total_assets         Float?
  total_liabilities    Float?
  deposit              Float?
  loan                 Float?
  net_interest_income  Float?
  operating_profit     Float?
  net_profit           Float?
  npl                  Float?
  capital_fund_to_rwa  Float?
  cost_of_fund         Float?
  base_rate            Float?
  interest_spread      Float?
  cd_ratio             Float?
  dps                  Float?
  sector_id            Int?
  promoter_shares      Float?
  public_shares        Float?
  share_registar       String?
  is_delisted          Boolean?
  is_merged            Boolean?
  core_capital         Float?
  gram_value           Float?
  prev_quarter_profit  Float?
  growth_rate          Float?
  close                Float?
  discount_rate        Float?
  pe_ratio             Float?
  peg_value            Float?
  scraped_at           DateTime @default(now())

  @@unique([symbol, fiscal_year, quarter])
  @@index([symbol])
  @@index([fiscal_year, quarter])
}

model fundamental_beta {
  id             Int      @id @default(autoincrement())
  symbol         String   @db.VarChar(20)
  beta           Float
  market_corr    Float?
  market_corr_p  Float?
  n_months       Int?
  period_start   DateTime?
  period_end     DateTime?
  computed_date  DateTime @default(now()) @db.Date

  @@unique([symbol, computed_date])
  @@index([symbol])
}

// ─────────────────────────────────────────────────────────────────────────────
// SECTOR & CORPORATE EVENTS
// ─────────────────────────────────────────────────────────────────────────────

model sector_momentum {
  id                    Serial
  date                  Text
  sector                Text
  weekly_return_pct     Text
  monthly_return_pct    Text
  avg_volume_change_pct Text
  momentum_score        Text
  status                Text
  top_stock_1           Text
  top_stock_2           Text
  catalyst              Text
  last_updated          Text

  @@index([date])
  @@index([sector])
}

model corporate_events {
  id                  Serial
  symbol              Text
  company             Text
  event_type          Text
  announcement_date   Text
  event_date          Text
  book_close_date     Text
  details             Text
  expected_impact_pct Text
  days_until_event    Text
  status              Text
  source              Text

  @@index([symbol])
  @@index([event_date])
}

// ─────────────────────────────────────────────────────────────────────────────
// DIVIDEND TRACKING
// ─────────────────────────────────────────────────────────────────────────────

model dividend_announcements {
  id                  Serial
  symbol              Text!
  company             Text
  sector              Text
  announcement_date   Text!          // YYYY-MM-DD — the event day (day 0)
  fiscal_year         Text           // e.g. "2080/81"
  dividend_type       Text           // CASH | BONUS | BOTH
  cash_dividend_pct   Text           // cash % of face value
  bonus_share_pct     Text           // bonus share %
  total_dividend_pct  Text           // total effective %
  book_close_date     Text           // last day to be eligible
  direction           Text           // INCREASE | DECREASE | UNCHANGED | FIRST_TIME
  prev_dividend_pct   Text           // previous year for comparison
  source              Text  @default("sharesansar")
  scraped_at          Text

  @@unique([symbol, announcement_date])
  @@index([symbol])
  @@index([announcement_date])
  @@index([direction])
  @@index([sector])
}

model dividend_pattern_study {
  id                    Serial
  symbol                Text!
  announcement_date     Text!
  sector                Text
  direction             Text          // INCREASE | DECREASE | UNCHANGED

  // Price drift before announcement
  price_drift_d10       Text          // % price change from day -10 to day 0
  price_drift_d6        Text          // % price change from day -6 to day 0
  price_drift_d4        Text          // % price change from day -4 to day 0
  price_drift_d2        Text          // % price change from day -2 to day 0

  // Volume momentum before announcement
  vol_ratio_d6          Text          // volume at day -6 / avg_volume_20d
  vol_ratio_d4          Text          // volume at day -4 / avg_volume_20d
  vol_ratio_d2          Text          // volume at day -2 / avg_volume_20d
  vol_ratio_d1          Text          // volume at day -1 / avg_volume_20d

  // Technical state before announcement
  rsi_d6                Text          // RSI at day -6
  rsi_d4                Text          // RSI at day -4
  obv_trend_d6_to_d1    Text          // RISING | FALLING | FLAT over -6 to -1
  atr_ratio_d6          Text          // ATR at -6 / avg_ATR_20d (compression = <1.0)
  macd_state_d4         Text          // ABOVE | BELOW signal line at day -4

  // Post-announcement outcome (for validating study)
  return_d0             Text          // % return on announcement day
  return_d1             Text          // % return on day +1
  return_d2_d9          Text          // cumulative % return day +2 to +9
  vs_nepse_d1           Text          // alpha vs NEPSE on day +1

  // Pattern classification
  pattern_detected      Text          // true | false — did pre-pattern fire?
  pattern_type          Text          // ACCUMULATION | DISTRIBUTION | NONE
  pattern_strength      Text          // STRONG | WEAK | NONE
  entry_feasible        Text          // true | false — was T+3 entry possible?
  optimal_entry_day     Text          // -6 | -5 | -4 | -3 — best day to enter

  in_dividend_season    Text
  event_type            Text
  fiscal_year           Text
  dividend_type         Text
  run_date              Text          // when this analysis was run

  @@unique([symbol, announcement_date])
  @@index([symbol])
  @@index([direction])
  @@index([pattern_detected])
  @@index([sector])
}

// ─────────────────────────────────────────────────────────────────────────────
// LEARNING & SELF-IMPROVEMENT
// ─────────────────────────────────────────────────────────────────────────────

// trade_journal: immutable raw record of every trade with full entry + exit context
// One row per trade. Written by auditor.py at trade close. Never updated.
model trade_journal {
  id          Serial
  created_at  Text           // YYYY-MM-DD HH:MM:SS NST

  // ── Identity
  symbol      Text!
  sector      Text
  paper_mode  Text           // true | false

  // ── Entry context (snapshot at moment of BUY signal)
  entry_date             Text
  entry_price            Text
  shares                 Text
  allocation_npr         Text

  primary_signal         Text  // MACD | BB_LOWER | SMA_CROSS | CANDLE | COMBO
  secondary_signal       Text
  candle_pattern         Text
  confidence_at_entry    Text  // claude_analyst confidence 0-100

  // Technical state at entry
  rsi_entry              Text
  macd_hist_entry        Text
  bb_signal_entry        Text
  ema_trend_entry        Text
  obv_trend_entry        Text
  conf_score_entry       Text
  volume_ratio_entry     Text
  atr_pct_entry          Text

  // Market context at entry
  market_state_entry     Text
  geo_score_entry        Text
  nepal_score_entry      Text
  combined_geo_entry     Text
  nepse_index_entry      Text

  // Planned exit levels
  stop_loss_planned      Text
  target_planned         Text
  hold_days_planned      Text

  // ── Exit context
  exit_date              Text
  exit_price             Text
  exit_reason            Text  // STOP_LOSS | TARGET_HIT | TRAILING_STOP | MANUAL | CIRCUIT_BREAKER | GEO_BLOCK

  // Market context at exit
  market_state_exit      Text
  geo_score_exit         Text
  nepal_score_exit       Text
  combined_geo_exit      Text
  nepse_index_exit       Text

  // ── Computed outcomes (filled by auditor.py)
  hold_days_actual       Text
  return_pct             Text
  pnl_npr                Text
  result                 Text  // WIN | LOSS | BREAKEVEN

  // Deltas — the critical causal layer
  geo_delta              Text
  nepal_delta            Text
  combined_geo_delta     Text
  nepse_return_pct       Text
  alpha_vs_nepse         Text

  // Loss attribution — computed by auditor.py _attribute_loss()
  loss_cause             Text  // MACRO_DETERIORATION | SIGNAL_FAILURE | MARKET_WIDE_SELLOFF | ENTRY_TIMING | STOP_TOO_TIGHT | SECTOR_EVENT | NULL

  // Learning link
  lesson_ids             Text

  @@index([symbol])
  @@index([result])
  @@index([primary_signal])
  @@index([entry_date])
  @@index([sector])
  @@index([loss_cause])
  @@index([paper_mode])
}

// learning_hub: synthesised lessons written by GPT weekly + research paper seeds
model learning_hub {
  id                 Serial
  created_at          Text
  date                Text
  lesson_type         Text   // SIGNAL_FILTER | SECTOR_FILTER | MACRO_FILTER | ENTRY_TIMING | STOP_CALC | PORTFOLIO_RULE | DIVIDEND_PATTERN | CALENDAR_EFFECT | FAILURE_MODE
  source              Text   // research_paper | gpt_weekly | claude | user
  symbol              Text   // specific symbol OR 'MARKET'
  sector              Text   // BANKING | NON_LIFE_INSURANCE | HYDRO | ALL etc
  applies_to          Text   // ALL | sector-specific | symbol-specific

  condition           Text   // machine-readable trigger condition
  finding             Text   // human-readable observation
  action              Text   // REDUCE_CONFIDENCE_BY_25 | BLOCK_ENTRY | REQUIRE_VOLUME_CONFIRM | etc

  trade_count         Text
  win_count           Text
  loss_count          Text
  win_rate            Text
  avg_return_pct      Text
  avg_pnl_npr         Text

  confidence_level    Text   // LOW | MEDIUM | HIGH

  loss_cause_primary  Text
  geo_delta_avg       Text
  nepal_delta_avg     Text
  alpha_vs_nepse_avg  Text

  active               Text  @default("true")
  superseded_by        Text   // forward pointer — id of lesson that replaced this one
  supersedes_lesson_id Text   // backward pointer — id of lesson this one replaced
  review_week          Text   // YYYY-WW — which Sunday GPT review wrote/updated this
  evidence_window_days Text   // how many days of data GPT reviewed when writing this
  market_log_ids       Text   // comma-separated market_log ids (WAIT/AVOID signals)
  gpt_reasoning        Text   // GPT's explanation for writing or superseding this lesson
  last_validated       Text
  validation_count     Text
  trade_journal_ids    Text

  @@index([symbol])
  @@index([sector])
  @@index([lesson_type])
  @@index([active])
  @@index([source])
  @@index([confidence_level])
}

// news_sentiment — DROPPED Apr 5 2026 (no writer/reader existed; nepal_pulse handles sentiment)

