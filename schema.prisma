// schema.prisma — NEPSE AI Engine
// Single source of truth for all tables.
// Edit here, then run: python db/codegen.py → python -m db.migrations
//
// Type conventions:
//   Text     — nullable TEXT column (most columns)
//   Text!    — NOT NULL TEXT column
//   Serial   — SERIAL PRIMARY KEY (auto-increment id)
//   Boolean  — TEXT storing "true"/"false" (kept as Text for simplicity)
//
// Annotations:
//   @id              — PRIMARY KEY
//   @unique          — UNIQUE INDEX
//   @default("val")  — DEFAULT value
//   @@index([col])   — regular index
//   @@index([a, b])  — composite index

// ─────────────────────────────────────────────────────────────────────────────
// PRICE & MARKET DATA
// ─────────────────────────────────────────────────────────────────────────────

model price_history {
  id           Serial
  date         Text!          // YYYY-MM-DD
  symbol       Text!
  open         Text
  high         Text
  low          Text
  close        Text
  ltp          Text
  volume       Text
  turnover     Text
  vwap         Text
  prev_close   Text
  transactions Text
  conf_score   Text
  avg_120d     Text
  avg_180d     Text
  week52_high  Text
  week52_low   Text
  source       Text  @default("sharesansar")

  @@unique([date, symbol])
  @@index([symbol])
  @@index([date])
}

model market_breadth {
  id                Serial
  date              Text!  @unique
  advancing         Text
  declining         Text
  unchanged         Text
  new_52w_high      Text
  new_52w_low       Text
  total_turnover_npr Text
  total_volume      Text
  breadth_score     Text
  market_signal     Text
  nepse_index       Text
  nepse_change_pct  Text
  timestamp         Text

  @@index([date])
}

