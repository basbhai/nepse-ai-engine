# ─────────────────────────────────────────────────────────────────────────────
# NEPSE AI Engine — Environment Variables
# Copy this to .env and fill in ALL values before running setup/install.sh
# NEVER commit .env to git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── OpenRouter (Claude + GPT + DeepSeek) ─────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key
CLAUDE_MODEL=anthropic/claude-sonnet-4-5
GPT_MODEL=openai/gpt-4o
DEEPSEEK_MODEL=deepseek/deepseek-r1

# ── TMS49 Broker ──────────────────────────────────────────────────────────────
TMS_USERNAME=your-tms-username
TMS_PASSWORD=your-tms-password
TMS_REQUEST_OWNER=109268
TMS_CLIENT_ID=2181770

# ── Meroshare ─────────────────────────────────────────────────────────────────
MEROSHARE_USERNAME=your-meroshare-username
MEROSHARE_PASSWORD=your-meroshare-password
MEROSHARE_DP_ID=your-dp-id
MEROSHARE_DEMAT=1301180000232764

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=5432461414

# ── Email (optional) ─────────────────────────────────────────────────────────
EMAIL_USER=your-gmail@gmail.com
EMAIL_APP_PASS=your-gmail-app-password
EMAIL_RECEIVER=your-email@gmail.com

# ── Trading mode ─────────────────────────────────────────────────────────────
# This is also stored in the DB settings table.
# The DB value takes precedence unless you pass -paper or -live on the CLI.
PAPER_MODE=true
