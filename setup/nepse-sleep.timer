[Unit]
Description=NEPSE AI — Sleep Scheduler Timer (April 2026)

[Timer]
# 3:45 PM NST = 10:00 UTC  — after EOD workflow
# 9:30 PM NST = 15:45 UTC  — after nightly summary workflow
OnCalendar=Mon,Tue,Wed,Thu,Fri 10:00:00 UTC
OnCalendar=Mon,Tue,Wed,Thu,Fri 15:45:00 UTC
# Sunday: 6:15 PM NST = 12:30 UTC — after weekly review
OnCalendar=Sun 12:30:00 UTC
Persistent=false
AccuracySec=60s

[Install]
WantedBy=timers.target
