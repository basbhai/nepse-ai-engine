[Unit]
Description=NEPSE AI — Weekly Review (Learning Hub + Capital Allocator)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=%i
WorkingDirectory=/opt/nepse-engine
ExecStart=/opt/nepse-engine/venv/bin/python -m workflows.weekly_workflow
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nepse-weekly
EnvironmentFile=/opt/nepse-engine/.env
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
